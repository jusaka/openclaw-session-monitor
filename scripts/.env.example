# Session Monitor Configuration
# Copy this file to .env and fill in your values.

# Telegram Bot
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# Session directory (default: ~/.openclaw/agents/main/sessions)
# SESSIONS_DIR=

# Agent name (shown in direct chat tags, e.g. "MyAgent")
AGENT_NAME=Agent

# Direct chat mappings: comma-separated "user_id:display_name" pairs
# Example: 123456789:Alice,987654321:Bob
DIRECT_USERS=

# Group chat mappings: comma-separated "group_id:display_name" pairs
# Example: -100123456789:My Group,-100987654321:Dev Chat
GROUPS=
